# MongoDB connection string. Leave unset in local dev to auto-start an
# in-memory MongoDB instance (data is wiped on restart) — set a real
# MongoDB Atlas URI for anything persistent or production.
MONGO_URI=

# Port the API server listens on.
PORT=5000

# Origin of the frontend app, used for CORS + cookie settings.
CLIENT_URL=http://localhost:5173

# Secrets used to sign JWTs — use long random strings in production.
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string

# Access tokens are short-lived; refresh tokens are long-lived and stored
# in an httpOnly cookie.
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Signs the short-lived (10 min) token issued after a correct password check
# but before the OTP step completes. Must differ from the other JWT secrets.
JWT_LOGIN_CHALLENGE_SECRET=replace-with-a-third-long-random-string

# All OTP/notification emails (signup verification, 2FA login codes) go
# through services/emailService.js, which picks a provider based on this
# one line — switching providers never requires touching any other file.
#   gmail   dev default: Gmail SMTP, delivers to any recipient, no domain
#           verification needed. See GMAIL_* below.
#   resend  production: Resend, needs a verified domain (see
#           services/email/resendProvider.js) — RESEND_API_KEY/OTP_FROM_EMAIL
#           below. Resend's sandbox sender (onboarding@resend.dev) can only
#           deliver to the email tied to the Resend account, which is why
#           this defaults to gmail for local dev.
EMAIL_PROVIDER=gmail

# Used when EMAIL_PROVIDER=gmail. GMAIL_USER must have 2-Step Verification
# enabled; GMAIL_APP_PASSWORD is a 16-character App Password from
# https://myaccount.google.com/apppasswords — NOT the account's normal
# login password (Google blocks that for SMTP).
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_FROM_NAME=Looppr

# Used when EMAIL_PROVIDER=resend. API key + sender for Resend (resend.com).
RESEND_API_KEY=
OTP_FROM_EMAIL=Looppr <onboarding@resend.dev>

# Used only by `npm run seed:admin` (scripts/seedAdmin.js) — the only way an
# admin account can be created, there is no public admin sign-up. Fill
# these in locally (never commit real values), run the seed script once,
# then remove them / rotate the password.
ADMIN_SEED_NAME=
ADMIN_SEED_EMAIL=
ADMIN_SEED_PHONE=
ADMIN_SEED_PASSWORD=

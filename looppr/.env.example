# Base URL of the Looppr API. Defaults to http://localhost:5000/api if unset.
VITE_API_URL=http://localhost:5000/api

# Production domain (no trailing slash), used for canonical URLs, sitemap.xml,
# and Open Graph tags. Defaults to https://getlooppr.com if unset.
VITE_SITE_URL=https://getlooppr.com

# Mapbox public token (starts with pk.) for the pickup-locations map on the
# dashboard. Free tier, no credit card required — get one at mapbox.com.
VITE_MAPBOX_TOKEN=
